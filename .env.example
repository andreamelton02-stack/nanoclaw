# Jeeves .env template — populate from a working install or OneCLI vault.
# Values intentionally blank.  Order grouped by purpose, not alphabetic.

# Core
ASSISTANT_NAME=
CONTAINER_IMAGE=
TZ=
ANTHROPIC_MODEL=
CLAUDE_CODE_OAUTH_TOKEN=

# Telegram channel
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_ROOT=

# Gmail (per-bot credentials dir; container HOME=/workspace/group)
GMAIL_CREDENTIALS_DIR=

# Calendar (comma-separated IDs; "primary" + any imported feeds)
CALENDAR_IDS=

# OneCLI credential proxy (v2 prep; v1 reads but does not require)
CREDENTIAL_PROXY_HOST=
CREDENTIAL_PROXY_PORT=

# OpenAI fallback model
OPENAI_API_KEY=
